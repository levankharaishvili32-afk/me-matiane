# ─── Supabase ───
# Get from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=  # ⚠️ SERVER-ONLY. Never commit. Never expose to frontend.

# ─── Resend ───
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM=me.matiane <noreply@me.matiane.ge>

# ─── AWS Rekognition (NSFW) ───
# IAM user with rekognition:DetectModerationLabels permission ONLY
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Cloudflare R2 ───
# Account ID + S3 API credentials
CF_ACCOUNT_ID=
CF_R2_ACCESS_KEY_ID=
CF_R2_SECRET_ACCESS_KEY=
CF_R2_BUCKET_PRIVATE=memat-originals
CF_R2_BUCKET_PUBLIC=memat-public
CF_R2_PUBLIC_DOMAIN=https://media.me.matiane.ge

# ─── Cloudflare Turnstile ───
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ─── Server pepper for OTP HMAC ───
# Generate with: openssl rand -hex 32
OTP_PEPPER=

# ─── App settings ───
APP_URL=https://me.matiane.ge
APP_ENV=development  # development | staging | production
